# Required to use the /admin dashboard. Set these in Vercel project env vars
# AND in a local `.env` file for `npm run dev` if you want to iterate locally.
#
# All five env vars are needed for the admin to commit changes back to GitHub.
# Without GITHUB_TOKEN + GITHUB_REPO, the admin still works locally but writes
# only to your local filesystem.

# Password the admin uses to gate /admin. Pick a strong one and store it in
# your password manager. This is the ONLY thing protecting your site's content
# from edits, so don't reuse a password.
ADMIN_PASSWORD=

# Random 32+ character string used to sign admin session cookies. Generate
# with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_SESSION_SECRET=

# GitHub Personal Access Token with `repo` scope (fine-grained: Contents
# read+write on this repo). The admin uses it to commit content changes
# which triggers a Vercel rebuild.
# https://github.com/settings/tokens
GITHUB_TOKEN=

# "owner/name", e.g. "jjking/jjking.xyz"
GITHUB_REPO=

# Branch the admin commits to. Defaults to "main".
GITHUB_BRANCH=main

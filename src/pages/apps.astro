---
import Base from '@layouts/Base.astro';
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';

const apps = (await getCollection('apps')).sort((a, b) => (b.data.year ?? 0) - (a.data.year ?? 0));

const statusLabel: Record<string, string> = {
  live: 'Live',
  beta: 'Beta',
  wip: 'WIP',
  archived: 'Archived',
};
---

<Base title="Apps" description="Apps and projects built by JJ King.">
  <section class="page-head">
    <div class="wrap">
      <div class="page-head-bar">
        <div class="eyebrow">Apps · Projects</div>
        <div class="eyebrow muted">{apps.length} {apps.length === 1 ? 'project' : 'projects'}</div>
      </div>
      <h1 class="display page-title">Small projects, ongoing experiments.</h1>
    </div>
  </section>

  {apps.length === 0 ? (
    <section class="wrap empty">
      <div class="empty-card">
        <div class="eyebrow">Nothing shipped yet</div>
        <p class="display empty-text">Workshop is open.</p>
      </div>
    </section>
  ) : (
    <section class="wrap apps">
      {apps.map((app, i) => (
        <article class="app">
          <div class="app-meta">
            <span class="eyebrow muted">№ {String(i + 1).padStart(2, '0')}</span>
            <span class={`eyebrow status status-${app.data.status}`}>● {statusLabel[app.data.status]}</span>
            {app.data.year && <span class="eyebrow muted">{app.data.year}</span>}
          </div>
          <div class="app-body">
            <h2 class="display app-title">{app.data.title}</h2>
            <p class="app-tag">{app.data.tagline}</p>
            {app.data.description && <p class="app-desc">{app.data.description}</p>}
            <div class="app-links">
              {app.data.url && <a href={app.data.url} target="_blank" rel="noreferrer" class="btn primary">Open ↗</a>}
              {app.data.repoUrl && <a href={app.data.repoUrl} target="_blank" rel="noreferrer" class="btn ghost">Source ↗</a>}
            </div>
          </div>
          {app.data.cover && (
            <div class="app-cover">
              <Image src={app.data.cover} alt={app.data.title} widths={[400, 800]} sizes="(max-width: 700px) 92vw, 360px" />
            </div>
          )}
        </article>
      ))}
    </section>
  )}
</Base>

<style>
  .page-head {
    padding: 56px 0 32px;
    border-bottom: 1px solid var(--rule-c);
  }
  .page-head-bar {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-bottom: 32px;
  }
  .page-title {
    font-size: clamp(40px, 7vw, 96px);
    line-height: 0.95;
    letter-spacing: -0.035em;
    max-width: 22ch;
  }

  .empty { padding: 96px var(--gutter); }
  .empty-card {
    text-align: center;
    padding: 64px 32px;
    border: 1px solid var(--rule-c);
    max-width: 560px;
    margin: 0 auto;
  }
  .empty-card .eyebrow { margin-bottom: 16px; }
  .empty-text { font-size: clamp(36px, 6vw, 56px); line-height: 1; }

  .apps { padding: 48px 0; }
  .app {
    display: grid;
    grid-template-columns: 140px 1fr 360px;
    gap: 32px;
    padding: 48px 0;
    border-bottom: 1px solid var(--rule-c);
    align-items: start;
  }
  .app:first-child { border-top: 1px solid var(--rule-c); }
  .app-meta {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }
  .status-live { color: #2b8a3e; }
  .status-beta { color: #d9831f; }
  .status-wip  { color: var(--accent); }
  .status-archived { color: var(--gray-2); }

  .app-title {
    font-size: clamp(32px, 4.5vw, 56px);
    line-height: 1;
    margin-bottom: 10px;
  }
  .app-tag {
    font-size: 13px;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: var(--accent);
    margin: 0 0 18px;
  }
  .app-desc {
    font-size: 14px;
    line-height: 1.6;
    max-width: 60ch;
    color: var(--muted);
    margin: 0 0 22px;
  }
  .app-links {
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
  }

  .app-cover {
    overflow: hidden;
    background: var(--bone-2);
  }
  .app-cover img { width: 100%; height: auto; display: block; }

  @media (max-width: 900px) {
    .app { grid-template-columns: 1fr; gap: 18px; }
    .app-meta { flex-direction: row; gap: 18px; flex-wrap: wrap; }
  }
</style>

---
export const prerender = false;
import { getSite } from '@lib/site';
import { COLLECTIONS } from '@lib/collections-meta';
import { isGithubLive } from '@lib/github';

const site = await getSite();
const collections = COLLECTIONS;
const liveGithub = isGithubLive();

// Pass collection metadata to the client as inline JSON
const collectionsJson = JSON.stringify(collections);
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <title>Admin · {site.siteName}</title>
    <meta name="robots" content="noindex" />
    <style>
      :root {
        color-scheme: dark;
        --bg: #0c0c0c;
        --bg-2: #161616;
        --bg-3: #1f1f1f;
        --fg: #f3efe6;
        --muted: #8a8a8a;
        --muted-2: #555;
        --rule: #2a2a2a;
        --accent: #ff5b3c;
        --good: #4ade80;
        --warn: #f0a020;
        --bad: #ff5b3c;
      }
      * { box-sizing: border-box; }
      html, body { margin: 0; padding: 0; height: 100%; }
      body {
        background: var(--bg);
        color: var(--fg);
        font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, monospace;
        font-size: 13px;
        line-height: 1.45;
      }
      a { color: inherit; }
      button { font: inherit; cursor: pointer; }
      input, textarea, select {
        font: inherit;
        background: var(--bg-2);
        color: var(--fg);
        border: 1px solid var(--rule);
        padding: 9px 10px;
        width: 100%;
      }
      input:focus, textarea:focus, select:focus {
        outline: none; border-color: var(--accent);
      }
      label { display: block; font-size: 10px; letter-spacing: 0.14em; text-transform: uppercase; color: var(--muted); margin-bottom: 6px; }
      .btn {
        padding: 9px 14px;
        background: var(--bg-2);
        color: var(--fg);
        border: 1px solid var(--rule);
        font-size: 12px;
        letter-spacing: 0.05em;
      }
      .btn:hover { border-color: var(--accent); color: var(--accent); }
      .btn.primary { background: var(--fg); color: var(--bg); border-color: var(--fg); }
      .btn.primary:hover { background: var(--accent); color: var(--fg); border-color: var(--accent); }
      .btn.danger { color: var(--bad); }
      .btn.danger:hover { background: var(--bad); color: var(--fg); border-color: var(--bad); }
      .btn[disabled] { opacity: 0.5; cursor: not-allowed; }

      /* ===== LAYOUT ===== */
      .app {
        display: grid;
        grid-template-columns: 240px 1fr;
        min-height: 100vh;
      }
      .sidebar {
        background: var(--bg);
        border-right: 1px solid var(--rule);
        padding: 20px 14px;
        position: sticky;
        top: 0;
        height: 100vh;
        overflow-y: auto;
      }
      .brand {
        font-size: 14px;
        font-weight: 700;
        letter-spacing: -0.01em;
        margin-bottom: 4px;
      }
      .brand-sub {
        font-size: 10px;
        letter-spacing: 0.14em;
        text-transform: uppercase;
        color: var(--muted);
        margin-bottom: 22px;
      }
      .nav-section {
        font-size: 10px;
        letter-spacing: 0.14em;
        text-transform: uppercase;
        color: var(--muted-2);
        padding: 14px 8px 6px;
      }
      .nav-item {
        display: block;
        padding: 8px 10px;
        text-decoration: none;
        font-size: 13px;
        border-left: 2px solid transparent;
        margin-bottom: 1px;
        cursor: pointer;
      }
      .nav-item:hover { background: var(--bg-2); }
      .nav-item.active {
        background: var(--bg-2);
        border-left-color: var(--accent);
        color: var(--accent);
      }
      .sidebar-foot {
        margin-top: auto;
        padding-top: 24px;
        border-top: 1px solid var(--rule);
        font-size: 11px;
        color: var(--muted);
      }
      .sidebar-foot a { display: block; padding: 4px 8px; text-decoration: none; }
      .sidebar-foot a:hover { color: var(--accent); }

      .main {
        padding: 28px 36px 80px;
        min-width: 0;
      }
      .head {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 24px;
        flex-wrap: wrap;
        gap: 14px;
      }
      .head h1 {
        margin: 0;
        font-size: 22px;
        letter-spacing: -0.01em;
      }
      .head-sub {
        font-size: 11px;
        color: var(--muted);
        letter-spacing: 0.06em;
        text-transform: uppercase;
        margin-top: 4px;
      }

      .banner {
        margin-bottom: 24px;
        padding: 12px 14px;
        background: #2a1c08;
        border: 1px solid #5a3a0c;
        color: #ffb060;
        font-size: 12px;
      }
      .banner.ok {
        background: #0c2218;
        border-color: #1e5a3a;
        color: #4ade80;
      }

      /* ===== LIST VIEW ===== */
      .list {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
        gap: 14px;
      }
      .card {
        background: var(--bg-2);
        border: 1px solid var(--rule);
        padding: 14px;
        cursor: pointer;
        transition: border-color 0.15s, transform 0.15s;
        display: flex;
        flex-direction: column;
        gap: 8px;
      }
      .card:hover { border-color: var(--accent); }
      .card .thumb {
        width: 100%;
        aspect-ratio: 4/3;
        background: var(--bg-3);
        object-fit: cover;
        border: 1px solid var(--rule);
      }
      .card .ttl { font-size: 13px; font-weight: 600; }
      .card .meta { font-size: 11px; color: var(--muted); letter-spacing: 0.04em; }

      .empty {
        padding: 60px 20px;
        text-align: center;
        color: var(--muted);
        border: 1px dashed var(--rule);
      }
      .empty button { margin-top: 14px; }

      /* ===== EDITOR DRAWER ===== */
      .drawer-bg {
        position: fixed;
        inset: 0;
        background: rgba(0,0,0,0.55);
        opacity: 0;
        visibility: hidden;
        transition: opacity 0.2s, visibility 0s 0.2s;
        z-index: 50;
      }
      .drawer-bg.open {
        opacity: 1;
        visibility: visible;
        transition: opacity 0.2s, visibility 0s;
      }
      .drawer {
        position: fixed;
        top: 0;
        right: 0;
        height: 100vh;
        width: min(620px, 100%);
        background: var(--bg);
        border-left: 1px solid var(--rule);
        z-index: 60;
        transform: translateX(100%);
        transition: transform 0.25s ease-out;
        display: flex;
        flex-direction: column;
      }
      .drawer.open { transform: translateX(0); }
      .drawer-head {
        padding: 18px 22px;
        border-bottom: 1px solid var(--rule);
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 12px;
      }
      .drawer-head h2 { margin: 0; font-size: 16px; }
      .drawer-body {
        flex: 1;
        overflow-y: auto;
        padding: 22px;
      }
      .drawer-body .field { margin-bottom: 18px; }
      .drawer-body textarea { resize: vertical; font-family: inherit; }
      .drawer-foot {
        padding: 14px 22px;
        border-top: 1px solid var(--rule);
        display: flex;
        justify-content: space-between;
        gap: 10px;
        background: var(--bg);
      }

      .help { font-size: 11px; color: var(--muted); margin-top: 4px; }

      /* Image field */
      .img-field { display: flex; gap: 12px; align-items: flex-start; }
      .img-preview {
        width: 110px;
        height: 110px;
        background: var(--bg-2);
        border: 1px solid var(--rule);
        object-fit: cover;
        flex-shrink: 0;
      }
      .img-controls { flex: 1; display: flex; flex-direction: column; gap: 8px; min-width: 0; }
      .img-controls .file-btn {
        padding: 9px 12px;
        border: 1px dashed var(--rule);
        text-align: center;
        cursor: pointer;
        background: var(--bg-2);
        color: var(--muted);
        font-size: 12px;
      }
      .img-controls .file-btn:hover { color: var(--accent); border-color: var(--accent); }
      .img-controls input[type=file] { display: none; }
      .img-controls .status { font-size: 11px; color: var(--muted); min-height: 14px; }
      .img-controls .status.err { color: var(--bad); }

      /* Sub-array fields (links, sidebar, sections) */
      .sub-rows { display: flex; flex-direction: column; gap: 10px; }
      .sub-row {
        background: var(--bg-2);
        border: 1px solid var(--rule);
        padding: 12px;
        display: flex;
        flex-direction: column;
        gap: 8px;
      }
      .sub-row.row2 {
        display: grid;
        grid-template-columns: 1fr 1.5fr 28px;
        gap: 8px;
        align-items: end;
      }
      .sub-row .x {
        background: transparent;
        border: 1px solid var(--rule);
        color: var(--muted);
        width: 28px; height: 28px;
        cursor: pointer;
      }
      .sub-row .x:hover { color: var(--bad); border-color: var(--bad); }
      .add-row-btn {
        padding: 8px 12px;
        background: transparent;
        border: 1px dashed var(--rule);
        color: var(--muted);
        font-size: 11px;
        letter-spacing: 0.06em;
        text-transform: uppercase;
      }
      .add-row-btn:hover { color: var(--accent); border-color: var(--accent); }

      /* Items inside a section */
      .section-items textarea { min-height: 60px; }

      /* Boolean */
      .bool { display: flex; gap: 8px; align-items: center; }
      .bool input[type=checkbox] { width: auto; }

      /* Toast */
      .toast {
        position: fixed;
        bottom: 20px;
        right: 20px;
        background: var(--bg-2);
        border: 1px solid var(--rule);
        color: var(--fg);
        padding: 12px 16px;
        z-index: 70;
        font-size: 12px;
        opacity: 0;
        transform: translateY(10px);
        transition: opacity 0.2s, transform 0.2s;
      }
      .toast.show { opacity: 1; transform: translateY(0); }
      .toast.err { border-color: var(--bad); color: var(--bad); }

      /* ===== MOBILE ===== */
      .menu-btn { display: none; }
      @media (max-width: 800px) {
        .app { grid-template-columns: 1fr; }
        .sidebar {
          position: fixed;
          left: 0; top: 0; bottom: 0;
          width: 260px;
          z-index: 80;
          transform: translateX(-100%);
          transition: transform 0.25s;
        }
        .sidebar.open { transform: translateX(0); }
        .main { padding: 18px 18px 80px; padding-top: 64px; }
        .menu-btn {
          display: flex;
          position: fixed;
          top: 12px;
          left: 12px;
          width: 40px;
          height: 40px;
          background: var(--bg-2);
          border: 1px solid var(--rule);
          align-items: center;
          justify-content: center;
          z-index: 70;
          color: var(--fg);
        }
        .drawer { width: 100%; }
        .sub-row.row2 { grid-template-columns: 1fr; }
      }
    </style>
  </head>
  <body>
    <button class="menu-btn" id="menu-btn" aria-label="Menu">☰</button>

    <div class="app">
      <aside class="sidebar" id="sidebar">
        <div class="brand">{site.siteName}</div>
        <div class="brand-sub">Admin</div>
        <nav id="collections-nav"></nav>
        <div class="sidebar-foot">
          <a href="/" target="_blank">View site ↗</a>
          <form action="/api/admin/logout" method="POST" style="margin:0">
            <a href="#" onclick="this.closest('form').submit(); return false;">Sign out</a>
          </form>
        </div>
      </aside>

      <main class="main">
        {!liveGithub && (
          <div class="banner" id="dev-banner">
            <strong>Local dev mode.</strong> Writes are going to your local filesystem (no GitHub commits). Set <code>GITHUB_TOKEN</code> + <code>GITHUB_REPO</code> in your env to flip to live mode.
          </div>
        )}

        <header class="head">
          <div>
            <h1 id="page-title">Loading…</h1>
            <div class="head-sub" id="page-sub"></div>
          </div>
          <button class="btn primary" id="new-btn" style="display:none">+ New</button>
        </header>

        <div id="content"></div>
      </main>
    </div>

    <!-- Editor drawer -->
    <div class="drawer-bg" id="drawer-bg"></div>
    <aside class="drawer" id="drawer" aria-hidden="true">
      <header class="drawer-head">
        <h2 id="drawer-title">Edit</h2>
        <button class="btn" id="drawer-close">Close</button>
      </header>
      <div class="drawer-body" id="drawer-body"></div>
      <footer class="drawer-foot">
        <button class="btn danger" id="drawer-delete" style="display:none">Delete</button>
        <div style="display:flex; gap:8px; margin-left:auto;">
          <button class="btn" id="drawer-cancel">Cancel</button>
          <button class="btn primary" id="drawer-save">Save</button>
        </div>
      </footer>
    </aside>

    <div class="toast" id="toast"></div>

    <script type="application/json" id="collections-data" set:html={collectionsJson}></script>
    <script src="/admin.js" type="module"></script>
  </body>
</html>

---
import Base from '@layouts/Base.astro';
import { getCollection } from 'astro:content';
import { getSite } from '@lib/site';

const site = await getSite();
const posts = (await getCollection('posts', ({ data }) => !data.draft))
  .sort((a, b) => b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf());

const tagSet = new Set<string>();
posts.forEach((p) => p.data.tags.forEach((t) => tagSet.add(t)));
const tags = Array.from(tagSet);
const ownerName = site.ownerName ?? site.siteName ?? '';
---

<Base title="Writing" description={`Essays, recipes, and notes${ownerName ? ' by ' + ownerName : ''}.`}>
  <section class="page-head">
    <div class="wrap">
      <div class="page-head-bar">
        <div class="eyebrow">Writing · Vol. 01</div>
        <div class="eyebrow muted">{posts.length} {posts.length === 1 ? 'post' : 'posts'}</div>
      </div>
      <h1 class="display page-title">Essays, recipes, and notes.</h1>
    </div>
  </section>

  {tags.length > 0 && (
    <section class="wrap tags-bar">
      <span class="eyebrow tags-label">Topics</span>
      <div class="tags-list">
        {tags.map((t) => <span class="tag">#{t}</span>)}
      </div>
    </section>
  )}

  {posts.length === 0 ? (
    <section class="wrap empty">
      <div class="empty-card">
        <div class="eyebrow">No posts yet</div>
        <p class="display empty-text">Draft mode.</p>
      </div>
    </section>
  ) : (
    <section class="wrap posts">
      {posts.map((post, i) => (
        <a href={`/writing/${post.slug}`} class="post-card">
          <span class="post-card-num mono">{String(posts.length - i).padStart(2, '0')}</span>
          <div class="post-card-body">
            <div class="post-card-meta">
              <span class="post-card-date">
                {post.data.publishedAt.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
              </span>
              {post.data.tags.length > 0 && (
                <span class="post-card-tags">{post.data.tags.map((t) => `#${t}`).join(' · ')}</span>
              )}
            </div>
            <h2 class="display post-card-title">{post.data.title}</h2>
            {post.data.description && (
              <p class="post-card-desc">{post.data.description}</p>
            )}
            <span class="post-card-cta">Read post →</span>
          </div>
        </a>
      ))}
    </section>
  )}
</Base>

<style>
  .page-head {
    padding: 56px 0 32px;
    border-bottom: 1px solid var(--rule-c);
  }
  .page-head-bar {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-bottom: 32px;
  }
  .page-title {
    font-size: clamp(40px, 7vw, 96px);
    line-height: 0.95;
    letter-spacing: -0.035em;
  }

  .tags-bar {
    padding: 22px 0;
    display: flex;
    gap: 18px;
    align-items: center;
    border-bottom: 1px solid var(--rule-c);
    flex-wrap: wrap;
  }
  .tags-label { color: var(--muted); }
  .tags-list { display: flex; gap: 8px; flex-wrap: wrap; }
  .tag {
    font-size: 11px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 3px 10px;
    border: 1px solid var(--rule-c);
    border-radius: 999px;
    color: var(--muted);
  }

  .empty { padding: 96px var(--gutter); }
  .empty-card {
    text-align: center;
    padding: 64px 32px;
    border: 1px solid var(--rule-c);
    max-width: 560px;
    margin: 0 auto;
  }
  .empty-card .eyebrow { margin-bottom: 16px; }
  .empty-text { font-size: clamp(36px, 6vw, 56px); line-height: 1; }

  .posts {
    padding: 48px 0;
    display: flex;
    flex-direction: column;
  }
  .post-card {
    display: grid;
    grid-template-columns: 56px 1fr;
    gap: 24px;
    padding: 36px 0;
    border-bottom: 1px solid var(--rule-c);
    transition: padding 0.25s var(--ease-snap), color 0.25s;
    align-items: start;
  }
  .post-card:first-child { border-top: 1px solid var(--rule-c); }
  .post-card:hover {
    padding-left: 16px;
    color: var(--accent);
  }
  .post-card-num {
    font-size: 11px;
    letter-spacing: 0.18em;
    color: var(--muted);
    padding-top: 4px;
  }
  .post-card-meta {
    display: flex;
    gap: 16px;
    font-size: 11px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--muted);
    margin-bottom: 10px;
  }
  .post-card-title {
    font-size: clamp(32px, 5vw, 64px);
    line-height: 0.98;
    margin-bottom: 10px;
  }
  .post-card-desc {
    margin: 0 0 16px;
    font-size: 14px;
    line-height: 1.55;
    color: var(--muted);
    max-width: 60ch;
  }
  .post-card-cta {
    font-size: 11px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--accent);
  }

  @media (max-width: 600px) {
    .post-card { grid-template-columns: 1fr; gap: 8px; }
  }
</style>

---
import Base from '@layouts/Base.astro';
import { getCollection } from 'astro:content';

const playlists = (await getCollection('playlists')).sort((a, b) => {
  const aT = a.data.createdAt?.valueOf() ?? 0;
  const bT = b.data.createdAt?.valueOf() ?? 0;
  return bT - aT;
});
---

<Base title="Playlists" description="Playlists curated by JJ King.">
  <section class="page-head">
    <div class="wrap">
      <div class="page-head-bar">
        <div class="eyebrow">Playlists · Mixtapes</div>
        <div class="eyebrow muted">{playlists.length} {playlists.length === 1 ? 'set' : 'sets'}</div>
      </div>
      <h1 class="display page-title">Sets I made for moods I keep returning to.</h1>
    </div>
  </section>

  {playlists.length === 0 ? (
    <section class="wrap empty">
      <div class="empty-card">
        <div class="eyebrow">Nothing queued</div>
        <p class="display empty-text">Mixtape in progress.</p>
      </div>
    </section>
  ) : (
    <section class="wrap playlists">
      {playlists.map((pl, i) => (
        <article class="pl">
          <div class="pl-cover" style={`background: ${pl.data.color ?? '#c4523c'};`}>
            <div class="pl-cover-meta">№ {String(i + 1).padStart(2, '0')}</div>
            <div class="pl-cover-text display">{pl.data.title}</div>
          </div>
          <div class="pl-meta">
            <div class="pl-meta-left">
              {pl.data.mood && <div class="eyebrow">{pl.data.mood}</div>}
              <h2 class="display pl-title">{pl.data.title}</h2>
              {pl.data.blurb && <p class="pl-blurb">{pl.data.blurb}</p>}
            </div>
            <div class="pl-meta-right">
              {pl.data.createdAt && (
                <div class="pl-date">
                  {pl.data.createdAt.toLocaleDateString('en-US', { month: 'short', year: 'numeric' })}
                </div>
              )}
              {pl.data.link && (
                <a href={pl.data.link} target="_blank" rel="noreferrer" class="btn ghost pl-btn">
                  Listen ↗
                </a>
              )}
            </div>
          </div>
          {pl.data.embedUrl && (
            <div class="pl-embed">
              <iframe
                src={pl.data.embedUrl}
                width="100%"
                height="152"
                frameborder="0"
                allowtransparency="true"
                allow="encrypted-media"
                loading="lazy"
              ></iframe>
            </div>
          )}
        </article>
      ))}
    </section>
  )}
</Base>

<style>
  .page-head {
    padding: 56px 0 32px;
    border-bottom: 1px solid var(--rule-c);
  }
  .page-head-bar {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-bottom: 32px;
  }
  .page-title {
    font-size: clamp(40px, 7vw, 96px);
    line-height: 0.95;
    letter-spacing: -0.035em;
    max-width: 22ch;
  }

  .empty { padding: 96px var(--gutter); }
  .empty-card {
    text-align: center;
    padding: 64px 32px;
    border: 1px solid var(--rule-c);
    max-width: 560px;
    margin: 0 auto;
  }
  .empty-card .eyebrow { margin-bottom: 16px; }
  .empty-text { font-size: clamp(36px, 6vw, 56px); line-height: 1; }

  .playlists {
    padding: 56px 0;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 56px 36px;
  }
  .pl-cover {
    aspect-ratio: 1 / 1;
    position: relative;
    overflow: hidden;
    color: #fff;
  }
  .pl-cover-meta {
    position: absolute;
    top: 18px;
    left: 18px;
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.85);
  }
  .pl-cover-text {
    position: absolute;
    left: 22px;
    right: 22px;
    bottom: 20px;
    font-size: clamp(32px, 4vw, 56px);
    line-height: 0.95;
  }
  .pl-meta {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    gap: 18px;
    margin-top: 16px;
  }
  .pl-title {
    font-size: clamp(22px, 2.6vw, 32px);
    margin: 6px 0 8px;
  }
  .pl-blurb {
    font-size: 13px;
    line-height: 1.5;
    color: var(--muted);
    max-width: 36ch;
    margin: 0;
  }
  .pl-meta-right {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 10px;
    flex-shrink: 0;
  }
  .pl-date {
    font-size: 11px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--muted);
  }

  .pl-embed { margin-top: 16px; }
  .pl-embed iframe { display: block; }

  @media (max-width: 720px) {
    .playlists { grid-template-columns: 1fr; gap: 48px; }
  }
</style>

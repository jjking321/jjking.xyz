---
import Base from '@layouts/Base.astro';
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';

const art = (await getCollection('art')).sort((a, b) => {
  const aT = a.data.createdAt?.valueOf() ?? 0;
  const bT = b.data.createdAt?.valueOf() ?? 0;
  return bT - aT;
});
---

<Base title="Art" description="Drawings and experiments by JJ King.">
  <section class="page-head">
    <div class="wrap">
      <div class="page-head-bar">
        <div class="eyebrow">Art · Sketchbook</div>
        <div class="eyebrow muted">{art.length} {art.length === 1 ? 'piece' : 'pieces'}</div>
      </div>
      <h1 class="display page-title">Drawings, prints, and small experiments.</h1>
    </div>
  </section>

  {art.length === 0 ? (
    <section class="wrap empty">
      <div class="empty-card">
        <div class="eyebrow">Nothing posted yet</div>
        <p class="display empty-text">Sketchbook warming up.</p>
      </div>
    </section>
  ) : (
    <section class="wrap art-grid">
      {art.map((piece, i) => (
        <article class:list={['art', i % 5 === 0 ? 'wide' : '']}>
          <div class="art-img">
            <Image
              src={piece.data.image}
              alt={piece.data.title}
              widths={[400, 800, 1200]}
              sizes="(max-width: 700px) 92vw, 46vw"
            />
          </div>
          <div class="art-meta">
            <div class="eyebrow">{piece.data.medium ?? 'Untitled medium'}</div>
            <h2 class="display art-title">{piece.data.title}</h2>
            {piece.data.caption && <p class="art-cap">{piece.data.caption}</p>}
          </div>
        </article>
      ))}
    </section>
  )}
</Base>

<style>
  .page-head {
    padding: 56px 0 32px;
    border-bottom: 1px solid var(--rule-c);
  }
  .page-head-bar {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-bottom: 32px;
  }
  .page-title {
    font-size: clamp(40px, 7vw, 96px);
    line-height: 0.95;
    letter-spacing: -0.035em;
    max-width: 18ch;
  }

  .empty { padding: 96px var(--gutter); }
  .empty-card {
    text-align: center;
    padding: 64px 32px;
    border: 1px solid var(--rule-c);
    max-width: 560px;
    margin: 0 auto;
  }
  .empty-card .eyebrow { margin-bottom: 16px; }
  .empty-text { font-size: clamp(36px, 6vw, 56px); line-height: 1; }

  .art-grid {
    padding: 56px 0;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 64px 32px;
  }
  .art.wide { grid-column: 1 / -1; }
  .art-img {
    overflow: hidden;
    background: var(--bone-2);
  }
  .art-img img {
    width: 100%;
    height: auto;
    display: block;
    transition: transform 0.7s var(--ease-out);
  }
  .art:hover .art-img img { transform: scale(1.02); }
  .art-meta { margin-top: 16px; }
  .art-title {
    font-size: clamp(24px, 3vw, 36px);
    margin: 6px 0 8px;
  }
  .art-cap {
    margin: 0;
    font-size: 13.5px;
    color: var(--muted);
    line-height: 1.5;
    max-width: 50ch;
  }

  @media (max-width: 720px) {
    .art-grid { grid-template-columns: 1fr; gap: 48px; }
    .art.wide { grid-column: auto; }
  }
</style>

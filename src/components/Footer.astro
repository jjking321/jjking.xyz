---
import { getSite } from '@lib/site';
const site = await getSite();
const year = new Date().getFullYear();
const indexLinks = (site.nav ?? []).filter((n) => n.href !== '/');
const channels = site.socials ?? [];
const ownerName = site.ownerName ?? site.siteName ?? '';
const location = site.location ?? '';

const isExternal = (url: string) => /^https?:\/\//.test(url);
---
<footer class="foot">
  <div class="wrap foot-inner">
    <div class="foot-block">
      <div class="eyebrow">Index</div>
      <div class="foot-links">
        {indexLinks.map(({ href, label }) => (
          <a class="link-underline" href={href}>{label}</a>
        ))}
      </div>
    </div>

    <div class="foot-block">
      <div class="eyebrow">Channels</div>
      <div class="foot-links">
        {channels.map(({ label, url }) => (
          <a class="link-underline" href={url}
             target={isExternal(url) ? '_blank' : undefined}
             rel={isExternal(url) ? 'noreferrer' : undefined}>
            {label}
          </a>
        ))}
      </div>
    </div>

    <div class="foot-block foot-stamp">
      <img src="/signature.png" alt={ownerName} class="foot-sig sig-dark" width="320" height="115" onerror="this.style.display='none'; this.nextElementSibling.style.display='none'; this.parentElement.classList.add('foot-stamp-text-only');" />
      <img src="/signature-dark.png" alt="" aria-hidden="true" class="foot-sig sig-light" width="320" height="115" onerror="this.style.display='none'" />
      <div class="foot-stamp-text">{ownerName}</div>
      <div class="foot-meta">©{year}{location ? ` · ${location}` : ''}</div>
    </div>
  </div>

</footer>

<style>
  .foot {
    border-top: 1px solid var(--rule-c);
    margin-top: 140px;
  }
  .foot-inner {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: 32px;
    padding: 56px var(--gutter) 48px;
  }
  .foot-block .eyebrow { margin-bottom: 16px; }
  .foot-links {
    display: flex;
    flex-direction: column;
    gap: 10px;
    font-size: 14px;
  }
  .foot-stamp { align-items: flex-end; text-align: right; }
  .foot-sig {
    width: clamp(200px, 24vw, 320px);
    height: auto;
    display: block;
    margin-left: auto;
  }
  .foot-stamp-text {
    display: none;
    font-family: var(--font-serif, Georgia, serif);
    font-style: italic;
    font-size: clamp(28px, 4vw, 42px);
    line-height: 1;
    color: var(--fg);
    text-align: right;
  }
  .foot-stamp.foot-stamp-text-only .foot-stamp-text { display: block; }
  @media (max-width: 720px) {
    .foot-stamp.foot-stamp-text-only .foot-stamp-text { text-align: left; }
  }
  .foot-stamp .sig-light { display: none; }
  :global([data-theme='light']) .foot-stamp .sig-dark { display: none; }
  :global([data-theme='light']) .foot-stamp .sig-light { display: block; }
  .foot-meta {
    margin-top: 14px;
    font-size: 11px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--muted);
  }
  @media (max-width: 720px) {
    .foot-inner { grid-template-columns: 1fr; gap: 28px; }
    .foot-stamp { align-items: flex-start; text-align: left; }
  }
</style>
